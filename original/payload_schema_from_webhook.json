{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Webhook Payload Schema",
    "type": "object",
    "properties": {
      "event_name": {
        "type": "string"
      },
      "data": {
        "type": "object",
        "properties": {
          "work_request": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "modified_fields": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "identifiers_of_modified_form_fields": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "links": {
                "type": "object",
                "properties": {
                  "self": { "type": "string", "format": "uri" },
                  "comments": { "type": "string", "format": "uri" },
                  "campaigns": { "type": "string", "format": "uri" },
                  "attachments": { "type": "string", "format": "uri" },
                  "creative_assets": { "type": "string", "format": "uri" }
                }
              }
            }
          }
        }
      }
    }
  }
